{
  "name": "ice-crawler",
  "displayName": "ICE Crawler",
  "version": "2.0.0",
  "description": "Triadic zero-trace repository ingestion engine — Frost telemetry, Glacier ephemeral materialization, Crystal deterministic crystallization, Residue lock. Real-time dashboard, AGNT thread submission, incremental mode, run history.",
  "author": "James Paul Jackson",
  "icon": "❄️",
  "homepage": "https://github.com/jacksonjp0311-gif/ICE-CRAWLER-AGNT-Plugin",
  "category": "analysis",
  "tags": ["repository","ingestion","code-analysis","triadic","zero-trace","crystallization","git","ai-handoff","dashboard","real-time","agnt"],
  "type": "module",
  "main": "./ice-crawler.js",
  "bin": { "ice-crawler": "./ice-crawler.js" },
  "engines": { "node": ">=18.0.0" },
  "tools": [
    {
      "type": "ice-crawler-ingest",
      "entryPoint": "./ice-crawler.js",
      "schema": {
        "title": "ICE Crawler Repo Ingestion",
        "description": "Ingest a Git repository through the triadic Frost→Glacier→Crystal→Residue pipeline.",
        "parameters": {
          "repo_url": { "type": "string", "required": true, "description": "Git repository URL" },
          "max_files": { "type": "number", "default": 60, "description": "Max files to crystallize" },
          "max_kb": { "type": "number", "default": 256, "description": "Max file size in KB" },
          "output_dir": { "type": "string", "description": "Custom output directory" },
          "enable_agentics": { "type": "boolean", "default": false, "description": "Enable φ-extremal agentics" }
        }
      }
    },
    {
      "type": "ice-crawler-estimate",
      "entryPoint": "./ice-crawler.js",
      "schema": {
        "title": "ICE Crawler Telemetry Estimate",
        "description": "Run Frost-only telemetry to resolve HEAD without cloning.",
        "parameters": {
          "repo_url": { "type": "string", "required": true, "description": "Git repository URL" }
        }
      }
    },
    {
      "type": "ice-crawler-dashboard",
      "entryPoint": "./ice-crawler.js",
      "schema": {
        "title": "ICE Crawler Dashboard",
        "description": "Launch real-time monitoring dashboard with AGNT integration.",
        "parameters": {
          "port": { "type": "number", "default": 8765, "description": "Dashboard port" }
        }
      }
    },
    {
      "type": "ice-crawler-submit",
      "entryPoint": "./ice-crawler.js",
      "schema": {
        "title": "ICE Crawler Submit to AGNT",
        "description": "Submit latest run results to AGNT to open an analysis thread.",
        "parameters": {
          "run_id": { "type": "string", "description": "Specific run ID (default: latest)" }
        }
      }
    },
    {
      "type": "ice-crawler-open-url",
      "entryPoint": "./open-url.js",
      "schema": {
        "title": "ICE Crawler Open Dashboard",
        "description": "Open the dashboard in external browser.",
        "parameters": {
          "url": { "type": "string", "required": true, "description": "Dashboard URL" }
        }
      }
    }
  ],
  "integrations": [
    { "service": "open-url-toolkit", "capability": "preview", "description": "Open dashboard in external browser" }
  ]
}
